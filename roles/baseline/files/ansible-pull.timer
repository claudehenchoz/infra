[Unit]
Description=Periodic ansible-pull

[Timer]
# 5 min after boot, then every 15 min. RandomizedDelay spreads load on
# GitHub when you have many boxes — they won't all hit the repo at :00.
OnBootSec=5min
OnUnitActiveSec=15min
RandomizedDelaySec=2min
Persistent=true

[Install]
WantedBy=timers.target
